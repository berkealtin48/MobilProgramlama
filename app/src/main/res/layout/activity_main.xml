<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp">


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="4"
        android:background="#FBF5F5"
        android:orientation="vertical">


        <TextView
            android:id="@+id/txtIslem"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="15dp"
            android:background="#F4E673"
            android:gravity="end|center_vertical"
            android:text=""
            android:textSize="32sp" />


        <TextView
            android:id="@+id/txtSonuc"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#8BC34A"
            android:gravity="end|center_vertical"
            android:text="0"
            android:textSize="32sp"
            android:textStyle="bold" />


        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:columnCount="5">



            <Button
                android:id="@+id/btn7"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="5dp"
                android:backgroundTint="#29B6F6"
                android:text="7"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn8"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="5dp"
                android:backgroundTint="#29B6F6"
                android:text="8"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn9"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="5dp"
                android:backgroundTint="#29B6F6"
                android:text="9"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnTopla"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="5dp"
                android:backgroundTint="#212121"
                android:text="+"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnYuzde"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="%"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn4"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="4"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn5"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="5"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn6"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="6"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnCikar"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="-"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnTers"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="1/x"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn1"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="1"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn2"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="2"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn3"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="3"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnCarp"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="*"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnUs"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="x^y"
                android:textSize="20sp" />


            <Button
                android:id="@+id/btn0"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#29B6F6"
                android:text="0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnTemizle"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#E53935"
                android:text="C"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnEsittir"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#43A047"
                android:text="="
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnBol"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="/"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnKok"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:backgroundTint="#212121"
                android:text="√x"
                android:textSize="20sp" />

        </GridLayout>
    </LinearLayout>


</LinearLayout>